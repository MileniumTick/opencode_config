{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "engram": {
      "command": [
        "engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "gitea": {
      "command": [
        "gitea-mcp",
        "-t",
        "stdio"
      ],
      "environment": {
        "GITEA_HOST": "https://gitea.istmocenter.com",
        "GITEA_ACCESS_TOKEN": "{file:.secrets/gitea-token}"
      },
      "enabled": true,
      "type": "local"
    },
    "plane": {
      "command": [
        "uvx",
        "plane-mcp-server",
        "stdio"
      ],
      "environment": {
        "PLANE_API_KEY": "{file:.secrets/plane-api-key}",
        "PLANE_BASE_URL": "https://plane.intranet.istmocenter.com",
        "PLANE_WORKSPACE_SLUG": "{file:.secrets/plane-workspace-slug}"
      },
      "enabled": true,
      "type": "local"
    }
  },
  "plugin": [],
  "default_agent": "team-lead",
  "agent": {
    "team-lead": {
      "temperature": 0.1,
      "steps": 20
    },
    "backend-lead": {
      "temperature": 0.1,
      "steps": 15
    },
    "frontend-lead": {
      "temperature": 0.1,
      "steps": 15
    },
    "data-lead": {
      "temperature": 0.1,
      "steps": 15
    },
    "security-lead": {
      "temperature": 0.1,
      "steps": 15
    },
    "rust-lead": {
      "temperature": 0.1,
      "steps": 15
    },
    "python-lead": {
      "temperature": 0.1,
      "steps": 15
    },
    "devops-lead": {
      "temperature": 0.1,
      "steps": 15
    },
    "mobile-lead": {
      "temperature": 0.1,
      "steps": 15
    },
    "golang-lead": {
      "temperature": 0.1,
      "steps": 15
    },
    "dev": {
      "steps": 30,
      "hidden": true
    },
    "exploration": {
      "steps": 30,
      "hidden": true
    },
    "security": {
      "steps": 30,
      "hidden": true
    },
    "qa": {
      "steps": 30,
      "hidden": true
    },
    "product-owner": {
      "temperature": 0.1,
      "steps": 10,
      "hidden": true
    },
    "ui-ux-partner": {
      "temperature": 0.1,
      "steps": 10,
      "hidden": true
    }
  }
}