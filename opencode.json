{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "engram": {
      "command": [
        "engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "gitea": {
      "command": [
        "gitea-mcp",
        "-t",
        "stdio"
      ],
      "environment": {
        "GITEA_HOST": "https://gitea.istmocenter.com",
        "GITEA_ACCESS_TOKEN": "{file:.secrets/gitea-token}"
      },
      "enabled": true,
      "type": "local"
    },
    "plane": {
      "command": [
        "uvx",
        "plane-mcp-server",
        "stdio"
      ],
      "environment": {
        "PLANE_API_KEY": "{file:.secrets/plane-api-key}",
        "PLANE_BASE_URL": "https://plane.intranet.istmocenter.com",
        "PLANE_WORKSPACE_SLUG": "{file:.secrets/plane-workspace-slug}"
      },
      "enabled": true,
      "type": "local"
    }
  },
  "plugin": [],
  "agent": {
    "team-lead": {
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "exploration": {
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "grep *": "allow",
          "find *": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git status": "allow",
          "cat *": "allow",
          "ls *": "allow"
        }
      }
    },
    "security": {
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "npm audit*": "allow",
          "bun audit*": "allow",
          "pip-audit*": "allow",
          "trivy fs*": "allow",
          "semgrep*": "allow",
          "grep *": "allow",
          "git log*": "allow",
          "git diff*": "allow"
        }
      }
    },
    "qa": {
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "npm test*": "allow",
          "bun test*": "allow",
          "vitest*": "allow",
          "pytest*": "allow",
          "cargo test*": "allow",
          "playwright*": "allow",
          "npm run lint*": "allow",
          "bun run lint*": "allow",
          "tsc*": "allow",
          "npm audit*": "allow",
          "git diff*": "allow",
          "git status": "allow"
        }
      }
    },
    "product-owner": {
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "ui-ux-partner": {
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "backend-lead": {
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "grep *": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git status": "allow"
        }
      }
    },
    "frontend-lead": {
