{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "engram": {
      "command": [
        "engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "gitea": {
      "command": [
        "gitea-mcp",
        "-t",
        "stdio"
      ],
      "environment": {
        "GITEA_HOST": "https://gitea.istmocenter.com",
        "GITEA_ACCESS_TOKEN": "{file:.secrets/gitea-token}"
      },
      "enabled": true,
      "type": "local"
    },
    "plane": {
      "command": [
        "uvx",
        "plane-mcp-server",
        "stdio"
      ],
      "environment": {
        "PLANE_API_KEY": "{file:.secrets/plane-api-key}",
        "PLANE_BASE_URL": "https://plane.intranet.istmocenter.com",
        "PLANE_WORKSPACE_SLUG": "{file:.secrets/plane-workspace-slug}"
      },
      "enabled": true,
      "type": "local"
    }
  },
  "plugin": [],
  "default_agent": "team-lead",
  "agent": {
    // --- Level 1: Primary Orchestrator ---
    "team-lead": {
      "temperature": 0.1,
      "steps": 20,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    // --- Level 2: Domain Leads ---
    "backend-lead": {
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "grep -r": "allow",
          "grep -n": "allow",
          "grep -l": "allow",
          "git log": "allow",
          "git log --oneline": "allow",
          "git log -p": "allow",
          "git diff": "allow",
          "git diff --stat": "allow",
          "git status": "allow",
          "git show": "allow"
        }
      }
    },
    "frontend-lead": {
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "grep -r": "allow",
          "grep -n": "allow",
          "grep -l": "allow",
          "git log": "allow",
          "git log --oneline": "allow",
          "git diff": "allow",
          "git diff --stat": "allow",
          "git status": "allow",
          "git show": "allow"
        }
      }
    },
    "data-lead": {
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "grep -r": "allow",
          "grep -n": "allow",
          "grep -l": "allow",
          "git log": "allow",
          "git log --oneline": "allow",
          "git diff": "allow",
          "git diff --stat": "allow",
          "git status": "allow",
          "git show": "allow"
        }
      }
    },
    "security-lead": {
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "grep -r": "allow",
          "grep -n": "allow",
          "grep -rn": "allow",
          "grep -l": "allow",
          "git log": "allow",
          "git log --oneline": "allow",
          "git log -p": "allow",
          "git diff": "allow",
          "git diff --stat": "allow",
          "git status": "allow",
          "git show": "allow"
        }
      }
    },
    "rust-lead": {
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "grep -r": "allow",
          "grep -n": "allow",
          "grep -l": "allow",
          "git log": "allow",
          "git log --oneline": "allow",
          "git diff": "allow",
          "git diff --stat": "allow",
          "git status": "allow",
          "git show": "allow"
        }
      }
    },
    "python-lead": {
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "grep -r": "allow",
          "grep -n": "allow",
          "grep -l": "allow",
          "git log": "allow",
          "git log --oneline": "allow",
          "git diff": "allow",
          "git diff --stat": "allow",
          "git status": "allow",
          "git show": "allow"
        }
      }
    },
    "devops-lead": {
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "docker ps": "allow",
          "docker ps -a": "allow",
          "docker inspect": "allow",
          "docker logs": "allow",
          "docker images": "allow",
          "docker network ls": "allow",
          "docker volume ls": "allow",
          "grep -r": "allow",
          "grep -n": "allow",
          "grep -l": "allow",
          "git log": "allow",
          "git log --oneline": "allow",
          "git diff": "allow",
          "git diff --stat": "allow",
          "git status": "allow",
          "git show": "allow"
        }
      }
    },
    "mobile-lead": {
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "grep -r": "allow",
          "grep -n": "allow",
          "grep -l": "allow",
          "git log": "allow",
          "git log --oneline": "allow",
          "git diff": "allow",
          "git diff --stat": "allow",
          "git status": "allow",
          "git show": "allow"
        }
      }
    },
    "golang-lead": {
      "temperature": 0.1,
      "steps": 15,
      "permission": {
        "edit": "deny",
        "bash": {
          "go test ./...": "allow",
          "go test -v ./...": "allow",
          "go vet ./...": "allow",
          "grep -r": "allow",
          "grep -n": "allow",
          "grep -l": "allow",
          "git log": "allow",
          "git log --oneline": "allow",
          "git diff": "allow",
          "git diff --stat": "allow",
          "git status": "allow",
          "git show": "allow"
        }
      }
    },
    // --- Level 3: Workers (hidden — invoked by leads only) ---
    "dev": {
      "steps": 30,
      "hidden": true
    },
    "exploration": {
      "steps": 30,
      "hidden": true,
      "permission": {
        "edit": "deny",
        "bash": {
          "ls": "allow",
          "ls -la": "allow",
          "ls -lh": "allow",
          "cat": "allow",
          "grep -r": "allow",
          "grep -n": "allow",
          "grep -rn": "allow",
          "grep -l": "allow",
          "grep -rl": "allow",
          "git log": "allow",
          "git log --oneline": "allow",
          "git log -p": "allow",
          "git diff": "allow",
          "git diff --stat": "allow",
          "git status": "allow",
          "git show": "allow",
          "git branch": "allow",
          "git remote -v": "allow"
        }
      }
    },
    "security": {
      "steps": 30,
      "hidden": true,
      "permission": {
        "edit": "deny",
        "bash": {
          "npm audit": "allow",
          "npm audit --json": "allow",
          "bun audit": "allow",
          "pip-audit": "allow",
          "pip-audit --json": "allow",
          "trivy fs": "allow",
          "trivy fs --format json": "allow",
          "semgrep --config auto": "allow",
          "semgrep --config p/owasp-top-ten": "allow",
          "semgrep --config p/secrets": "allow",
          "grep -r": "allow",
          "grep -n": "allow",
          "grep -rn": "allow",
          "grep -l": "allow",
          "git log": "allow",
          "git log --oneline": "allow",
          "git log -p": "allow",
          "git diff": "allow",
          "git diff --stat": "allow",
          "git show": "allow"
        }
      }
    },
    "qa": {
      "steps": 30,
      "hidden": true,
      "permission": {
        "edit": "deny",
        "bash": {
          "npm test": "allow",
          "npm run test": "allow",
          "npm run lint": "allow",
          "npm audit": "allow",
          "bun test": "allow",
          "bun run test": "allow",
          "bun run lint": "allow",
          "vitest run": "allow",
          "vitest run --reporter verbose": "allow",
          "pytest": "allow",
          "pytest -v": "allow",
          "pytest --tb=short": "allow",
          "cargo test": "allow",
          "cargo test --verbose": "allow",
          "playwright test": "allow",
          "playwright test --reporter=list": "allow",
          "tsc --noEmit": "allow",
          "git diff": "allow",
          "git diff --stat": "allow",
          "git status": "allow"
        }
      }
    },
    "product-owner": {
      "temperature": 0.1,
      "steps": 10,
      "hidden": true,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "ui-ux-partner": {
      "temperature": 0.1,
      "steps": 10,
      "hidden": true,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3:8b-16k": {
          "tools": true
        }
      }
    }
  }
}
