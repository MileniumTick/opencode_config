{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "backend-dev": {
      "description": "Backend specialist - Elysia, Drizzle, PostgreSQL, Redis",
      "mode": "subagent",
      "prompt": "{file:./agents/backend-dev.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "glob": true,
        "read": true,
        "write": true
      }
    },
    "frontend-dev": {
      "description": "Frontend specialist - React, Vite, TanStack, Tailwind",
      "mode": "subagent",
      "prompt": "{file:./agents/frontend-dev.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-orchestrator": {
      "description": "Coordinates complex tasks by delegating to specialist agents",
      "mode": "primary",
      "prompt": "{file:./agents/sdd-orchestrator.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-explore": {
      "description": "Investiga el codebase, identifica riesgos",
      "mode": "subagent",
      "prompt": "file:/home/josue/.agents/skills/sdd-workflow/skills/sdd-explore/SKILL.md",
      "task_budget": 2
    },
    "sdd-spec": {
      "description": "Escribe specs delta con Given/When/Then",
      "mode": "subagent",
      "prompt": "file:/home/josue/.agents/skills/sdd-workflow/skills/sdd-spec/SKILL.md",
      "task_budget": 1
    },
    "sdd-tasks": {
      "description": "Crea lista de tareas en fases",
      "mode": "subagent",
      "prompt": "file:/home/josue/.agents/skills/sdd-workflow/skills/sdd-tasks/SKILL.md",
      "task_budget": 1
    },
    "sdd-apply": {
      "description": "Implementa código siguiendo specs",
      "mode": "subagent",
      "prompt": "file:/home/josue/.agents/skills/sdd-workflow/skills/sdd-apply/SKILL.md",
      "task_budget": 3
    },
    "sdd-verify": {
      "description": "Valida implementación contra specs",
      "mode": "subagent",
      "prompt": "file:/home/josue/.agents/skills/sdd-workflow/skills/sdd-verify/SKILL.md",
      "task_budget": 2
    },
    "sdd-archive": {
      "description": "Cierra cambio y persiste estado",
      "mode": "subagent",
      "prompt": "file:/home/josue/.agents/skills/sdd-workflow/skills/sdd-archive/SKILL.md",
      "task_budget": 1
    },
    "quick-delegate": {
      "description": "Routing rápido para tareas pequeñas",
      "mode": "subagent",
      "prompt": "file:/home/josue/.agents/skills/sdd-workflow/skills/quick-delegate/SKILL.md",
      "task_budget": 2
    }
  },
  "default_agent": "sdd-orchestrator",
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "engram": {
      "command": [
        "engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "gitea": {
      "command": [
        "gitea-mcp",
        "-t",
        "stdio"
      ],
      "environment": {
        "GITEA_BASE_URL": "https://gitea.istmocenter.com",
        "GITEA_TOKEN": "{file:.secrets/gitea-token}"
      },
      "type": "local"
    },
    "plane": {
      "command": [
        "uvx",
        "plane-mcp-server",
        "stdio"
      ],
      "environment": {
        "PLANE_API_KEY": "{file:.secrets/plane-api-key}",
        "PLANE_BASE_URL": "https://plane.intranet.istmocenter.com",
        "PLANE_WORKSPACE_SLUG": "{file:.secrets/plane-workspace-slug}"
      },
      "type": "local"
    }
  },
  "permission": {
    "task": {
      "*": "allow"
    },
    "skill": {
      "*": "allow"
    },
    "bash": {
      "*": "allow",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "command": "ask",
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow"
    }
  }
}
